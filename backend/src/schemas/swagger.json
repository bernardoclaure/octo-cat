{
  "openapi": "3.0.0",
  "info": {
    "title": "OctoCAT Purchase Order API",
    "version": "0.1.0"
  },
  "paths": {
    "/api/purchase-orders": {
      "post": {
        "summary": "Create a draft purchase order",
        "responses": {
          "201": {
            "description": "Purchase order created"
          }
        }
      }
    },
    "/api/purchase-orders/{purchaseOrderId}/submit": {
      "post": {
        "summary": "Submit a draft purchase order",
        "responses": {
          "200": {
            "description": "Purchase order submitted"
          }
        }
      }
    },
    "/api/purchase-orders/{purchaseOrderId}/approve": {
      "post": {
        "summary": "Approve a submitted purchase order",
        "responses": {
          "200": {
            "description": "Purchase order approved"
          }
        }
      }
    },
    "/api/purchase-orders/{purchaseOrderId}/fulfill": {
      "post": {
        "summary": "Record partial or full fulfillment for an approved purchase order",
        "responses": {
          "200": {
            "description": "Purchase order fulfillment recorded"
          }
        }
      }
    },
    "/api/purchase-orders/{purchaseOrderId}/fulfillment-history": {
      "get": {
        "summary": "Get fulfillment history for a purchase order",
        "responses": {
          "200": {
            "description": "Fulfillment history returned"
          }
        }
      }
    },
    "/api/purchase-orders/{purchaseOrderId}/cancel": {
      "post": {
        "summary": "Cancel a purchase order",
        "responses": {
          "200": {
            "description": "Purchase order cancelled"
          }
        }
      }
    }
  }
}
